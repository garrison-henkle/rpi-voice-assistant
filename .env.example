# Satellite + assistant config. Copy this file to `.env` and edit; nothing
# here is hot-read by the satellite, so changes need a container restart.
# The defaults below match the official recommmended Pi 5 / 8 GB stack.

# ---------------------------------------------------------------------------
# LLM (Ollama)
# ---------------------------------------------------------------------------
# Parent model pulled inside the ollama container; setup.sh substitutes this
# into models/voice-assistant.template.Modelfile and tags the result as
# `voice-assistant` in ollama. Switch and re-run setup.sh to swap models.
#
#   qwen3:0.6b      ~700 ms first token on Pi 5 CPU; weakest at tool calls
#   qwen3:1.7b      ~1.8 s first token; the previous default
#   qwen3:4b        ~3.0 s first token; reliable Koog tool calls
#   llama3.2:1b     ~1.2 s first token; mixed tool-calling accuracy
RPI_LLM_BASE_MODEL=qwen3:0.6b
RPI_LLM_MODEL=voice-assistant
RPI_LLM_NUM_CTX=2048
RPI_LLM_NUM_PREDICT=256

# ---------------------------------------------------------------------------
# TTS (Piper)
# ---------------------------------------------------------------------------
RPI_TTS_VOICE=en_US-hfc_male-medium
# Same value, picked up by the piper container's startup wrapper.
PIPER_VOICE=en_US-hfc_male-medium

# ---------------------------------------------------------------------------
# Satellite
# ---------------------------------------------------------------------------
SAT_WAKE_TH_WORD=hey_rhasspy
SAT_WAKE_THRESHOLD=0.5
SAT_VAD_RMS_QUIET=200
SAT_VAD_QUIET_FRAMES=8
SAT_SAMPLE_RATE=16000
# Empty / `auto` picks BT (when Sonos paired) or wired (default alias) at boot.
SAT_OUTPUT_DEVICE=auto
# Empty means auto-pick the first capture-capable ALSA device.
SAT_INPUT_DEVICE=

# ---------------------------------------------------------------------------
# Bluetooth sink (Sonos)
# ---------------------------------------------------------------------------
SONOS_BT_MAC=74:CA:60:A6:F3:F8
