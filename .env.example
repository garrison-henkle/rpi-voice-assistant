# Satellite runtime configuration.
#
# Copy to `.env` before running `sh ./scripts/setup.sh` first time.

### Audio socket owner (UID + GID)
# The assistant-satellite container needs read/write access to your
# PulseAudio/PipeWire socket. Run `id -u` and `id -g` as the host user that
# owns the audio stack and put those numbers here. 1000 is the default first
# user on Debian; change to match your real account.
SATELLITE_USER_ID=1000
SATELLITE_USER_GROUP=1000

### PipeWire / PulseAudio socket paths on the host
LVA_PULSE_SERVER=/run/user/1000/pulse/native
LVA_XDG_RUNTIME_DIR=/run/user/1000
LVA_PULSE_COOKIE=/run/user/1000/pulse/cookie
