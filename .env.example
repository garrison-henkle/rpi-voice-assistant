# linux-voice-assistant runtime configuration.
#
# Copy to `.env` on first setup and edit to match your host:
#     cp .env.example .env
#
# Required for any host that runs the satellite directly.  See
# https://github.com/OHF-Voice/linux-voice-assistant/blob/main/docs/install_application.md
# for the full env reference.

### Audio socket owner (UID + GID)
# LVA inside the container needs read/write access to your PipeWire/PulseAudio
# socket. Run `id -u` and `id -g` as the host user that owns the audio
# stack and put those numbers here. 1000 is the default first user on Debian;
# change to match your real account.
LVA_USER_ID=1000
LVA_USER_GROUP=1000

### PipeWire / PulseAudio socket paths on the host
# PipeWire (Debian/Ubuntu default):  /run/user/$UID/pulse/native
# PulseAudio (legacy):               /run/user/$UID/pulse/native   (same path)
# Some Debian builds need a `:unix` prefix on PULSE_SERVER — uncomment if
# LVA's logs complain about a missing socket.
LVA_PULSE_SERVER=/run/user/1000/pulse/native
LVA_XDG_RUNTIME_DIR=/run/user/1000
LVA_PULSE_COOKIE=/run/user/1000/pulse/cookie

### Bind address + port
# HOST defaults to 0.0.0.0 so LVA can bind one network card and be discovered
# by Home Assistant over mDNS. PORT matches the orchestrator (rpi-assistant)
# container's published 6053/tcp in `docker-compose.yml`. If you change one,
# change the other.
HOST=0.0.0.0
PORT=6053

### Friendly name shown in HA's ESPHome device picker
CLIENT_NAME=rpi-nest-mini

### Wake word (overridden in LVA's preferences UI if you want)
# WAKE_MODEL=okay_nabu
