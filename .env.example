# Satellite + assistant config. Copy this file to `.env` and edit; nothing
# here is hot-read by the satellite, so changes need a container restart.
# The defaults below match the official recommmended Pi 5 / 8 GB stack.

# ---------------------------------------------------------------------------
# LLM (Ollama)
# ---------------------------------------------------------------------------
# Parent model pulled inside the ollama container; setup.sh substitutes this
# into models/voice-assistant.template.Modelfile and tags the result as
# `voice-assistant` in ollama. Switch and re-run setup.sh to swap models.
#
#   qwen3:0.6b      ~700 ms first token on Pi 5 CPU; weakest at tool calls
#   qwen3:1.7b      ~1.8 s first token; the previous default
#   qwen3:4b        ~3.0 s first token; reliable Koog tool calls
#   llama3.2:1b     ~1.2 s first token; mixed tool-calling accuracy
RPI_LLM_BASE_MODEL=qwen3:0.6b
RPI_LLM_MODEL=voice-assistant
RPI_LLM_NUM_CTX=2048
RPI_LLM_NUM_PREDICT=256

# ---------------------------------------------------------------------------
# TTS (Piper)
# ---------------------------------------------------------------------------
RPI_TTS_VOICE=en_US-hfc_male-medium
# Same value, picked up by the piper container's startup wrapper.
PIPER_VOICE=en_US-hfc_male-medium

# ---------------------------------------------------------------------------
# Satellite
# ---------------------------------------------------------------------------
SAT_WAKE_TH_WORD=hey_rhasspy
SAT_WAKE_THRESHOLD=0.5
SAT_VAD_RMS_QUIET=100
SAT_VAD_QUIET_FRAMES=5
SAT_VAD_MAX_FRAMES=480
SAT_SAMPLE_RATE=16000
# 1 → push each captured 80 ms block into moonshine's `add_audio` +
# `update_transcription` loop while we are still recording. Faster
# end-of-utterance latency vs the offline batch path. 0 → fall back
# to one-shot `transcribe_without_streaming` (no concurrency).
SAT_STREAMING_ASR=1
# 1 → queue a synthetic ascending arpeggio onto the output device when
# the orchestrator reports a tool call, covering the empty-content
# gap. 0 → no chime.
SAT_CHIME_ON_TOOL=1
# 1 → probe ollama + piper at satellite startup so the first wake
# doesn't pay a cold-load tax. 0 → skip pre-warm.
SAT_PREWARM=1
# URLs of the dependencies used by SAT_PREWARM. Defaults assume the
# docker bridge names from docker-compose.yml. Override only when
# testing outside the compose stack.
RPI_LLM_TAGS_URL=http://ollama:11434/api/tags
RPI_TTS_HEALTH_URL=http://piper:5000/info
# Empty / `auto` picks BT (when Sonos paired) or wired (default alias) at boot.
SAT_OUTPUT_DEVICE=auto
# Empty means auto-pick the first capture-capable ALSA device.
SAT_INPUT_DEVICE=

# ---------------------------------------------------------------------------
# Orchestrator (rpi-assistant)
# ---------------------------------------------------------------------------
# 1 → when the LLM emits `message.tool_calls`, run them through the
# locally-registered executor and stream the canned ack straight to
# piper, skipping the second LLM round-trip. Disable to let the LLM
# narrate its own acknowledgement.
RPI_LLM_SKIP_POST_TOOL_RESP=1

# ---------------------------------------------------------------------------
# Bluetooth sink (Sonos)
# ---------------------------------------------------------------------------
SONOS_BT_MAC=74:CA:60:A6:F3:F8
